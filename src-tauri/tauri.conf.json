{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Git Update Manager",
  "version": "1.0.0",
  "identifier": "com.gitupdater.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [{
      "title": "Git Update Manager",
      "width": 900,
      "height": 650,
      "center": true,
      "resizable": true
    }]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../assets-windows"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
