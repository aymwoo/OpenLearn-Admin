{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Git Update Manager",
  "version": "1.0.0",
  "identifier": "com.gitupdater.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [{
      "title": "Git Update Manager",
      "width": 900,
      "height": 650,
      "center": true,
      "resizable": true
    }]
  }
}
